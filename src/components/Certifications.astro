---
const certifications = [
  {
    title: 'Oracle Academy Java Fundamental',
    issuer: 'Oracle Academy',
    icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
    color: 'from-red-500 to-orange-500'
  },
  {
    title: 'Oracle Database Design',
    issuer: 'Oracle Academy',
    icon: 'M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4',
    color: 'from-red-500 to-pink-500'
  },
  {
    title: 'CCNA: Introduction to Networks',
    issuer: 'Cisco Networking Academy',
    icon: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9',
    color: 'from-blue-500 to-cyan-500'
  },
  {
    title: 'CCNA 2: Switching, Routing, and Wireless Essentials',
    issuer: 'Cisco Networking Academy',
    icon: 'M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
    color: 'from-blue-600 to-indigo-500'
  },
  {
    title: 'Cisco MTCNA',
    issuer: 'Cisco Networking Academy',
    icon: 'M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z',
    color: 'from-cyan-500 to-teal-500'
  }
];
---

<section id="certifications" class="py-20 bg-gray-900 relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute top-0 left-1/2 w-96 h-96 bg-blue-500/10 rounded-full blur-3xl"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-16" data-aos="fade-up">
      <h2 class="text-4xl sm:text-5xl font-bold font-space-grotesk mb-4">
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500">Certifications</span>
      </h2>
      <div class="w-20 h-1 bg-gradient-to-r from-cyan-400 to-blue-500 mx-auto mb-4"></div>
      <p class="text-gray-400 max-w-2xl mx-auto">
        Sertifikasi profesional yang telah saya raih untuk meningkatkan kompetensi
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {certifications.map((cert, index) => (
        <div 
          class="group bg-gray-950/50 backdrop-blur-sm rounded-2xl p-6 border border-gray-800 hover:border-cyan-500/50 transition-all duration-300 hover:transform hover:scale-105"
          data-aos="fade-up"
          data-aos-delay={index * 100}
        >
          <div class="flex items-start gap-4">
            <div class={`w-12 h-12 bg-gradient-to-br ${cert.color} rounded-xl flex items-center justify-center flex-shrink-0 group-hover:rotate-12 transition-transform duration-300`}>
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={cert.icon}></path>
              </svg>
            </div>
            
            <div class="flex-1">
              <h3 class="text-lg font-bold text-white mb-2 font-space-grotesk group-hover:text-cyan-400 transition-colors duration-300">
                {cert.title}
              </h3>
              <p class="text-sm text-gray-400 flex items-center gap-2">
                <svg class="w-4 h-4 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                </svg>
                {cert.issuer}
              </p>
            </div>
          </div>
          
          <div class="mt-4 pt-4 border-t border-gray-800">
            <div class="flex items-center justify-between text-sm">
              <span class="text-cyan-400 font-medium">Verified</span>
              <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
            </div>
          </div>
        </div>
      ))}
    </div>
    
    <!-- Additional Info -->
    <div class="mt-12 text-center" data-aos="fade-up" data-aos-delay="600">
      <div class="inline-block bg-gradient-to-r from-cyan-500/10 to-blue-500/10 border border-cyan-500/30 rounded-full px-6 py-3">
        <p class="text-gray-300">
          <span class="text-cyan-400 font-semibold">Continuous Learning:</span> Aktif mengikuti program sertifikasi untuk meningkatkan skill
        </p>
      </div>
    </div>
  </div>
</section>
