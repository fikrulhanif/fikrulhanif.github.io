---
const skillCategories = [
  {
    title: 'Web Development',
    icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
    skills: ['HTML', 'CSS', 'JavaScript', 'PHP', 'SQL']
  },
  {
    title: 'Framework',
    icon: 'M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10',
    skills: ['CodeIgniter 4', 'Laravel', 'React', 'Flutter', 'WordPress']
  },
  {
    title: 'Tools',
    icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z',
    skills: ['Git', 'Figma', 'Canva', 'Postman', 'DBMS']
  }
];
---

<section id="skills" class="py-20 bg-gray-900 relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute top-1/2 left-0 w-96 h-96 bg-blue-500/10 rounded-full blur-3xl"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-16" data-aos="fade-up">
      <h2 class="text-4xl sm:text-5xl font-bold font-space-grotesk mb-4">
        Skills & <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500">Tools</span>
      </h2>
      <div class="w-20 h-1 bg-gradient-to-r from-cyan-400 to-blue-500 mx-auto mb-4"></div>
      <p class="text-gray-400 max-w-2xl mx-auto">
        Teknologi dan tools yang saya gunakan untuk membangun solusi digital modern
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {skillCategories.map((category, index) => (
        <div 
          class="bg-gray-950/50 backdrop-blur-sm rounded-2xl p-8 border border-gray-800 hover:border-cyan-500/50 transition-all duration-300 hover:transform hover:scale-105 group"
          data-aos="fade-up"
          data-aos-delay={index * 100}
        >
          <div class="flex items-center gap-4 mb-6">
            <div class="w-14 h-14 bg-gradient-to-br from-cyan-400 to-blue-500 rounded-xl flex items-center justify-center group-hover:rotate-12 transition-transform duration-300">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={category.icon}></path>
              </svg>
            </div>
            <h3 class="text-2xl font-bold text-white font-space-grotesk">{category.title}</h3>
          </div>
          
          <div class="flex flex-wrap gap-2">
            {category.skills.map((skill) => (
              <span class="px-4 py-2 bg-gray-800/50 text-cyan-400 rounded-lg text-sm font-medium border border-gray-700 hover:border-cyan-500/50 hover:bg-gray-800 transition-all duration-300">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
    
    <!-- Additional Skills Info -->
    <div class="mt-12 text-center" data-aos="fade-up" data-aos-delay="400">
      <div class="inline-block bg-gradient-to-r from-cyan-500/10 to-blue-500/10 border border-cyan-500/30 rounded-full px-6 py-3">
        <p class="text-gray-300">
          <span class="text-cyan-400 font-semibold">Always Learning:</span> Terus mengeksplorasi teknologi baru dan best practices
        </p>
      </div>
    </div>
  </div>
</section>
