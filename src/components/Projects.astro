---
const projects = [
  {
    title: 'Sistem Informasi Akademik (SIAKAD)',
    description: 'Aplikasi manajemen akademik lengkap dengan fitur pengelolaan mahasiswa, dosen, mata kuliah, dan nilai. Dilengkapi dengan sistem autentikasi multi-role dan dashboard interaktif.',
    tech: ['CodeIgniter 4', 'MySQL', 'Bootstrap', 'JavaScript'],
    features: ['CRUD Management', 'Multi-role Auth', 'Report Generation', 'Responsive Design'],
    gradient: 'from-purple-500 to-pink-500'
  },
  {
    title: 'Website Rental Mobil',
    description: 'Platform rental mobil online dengan sistem booking, manajemen armada, dan tracking status kendaraan. Terintegrasi dengan sistem pembayaran dan notifikasi otomatis.',
    tech: ['CodeIgniter 4', 'MySQL', 'jQuery', 'CSS3'],
    features: ['Booking System', 'Payment Integration', 'Fleet Management', 'Email Notification'],
    gradient: 'from-cyan-500 to-blue-500'
  },
  {
    title: 'Website Booking',
    description: 'Sistem reservasi online untuk berbagai layanan dengan kalender interaktif, manajemen slot waktu, dan konfirmasi otomatis. Mendukung multiple service providers.',
    tech: ['CodeIgniter 4', 'MySQL', 'AJAX', 'Bootstrap'],
    features: ['Real-time Booking', 'Calendar Integration', 'Auto Confirmation', 'Admin Dashboard'],
    gradient: 'from-green-500 to-teal-500'
  },
  {
    title: 'E-Commerce Sepatu',
    description: 'Platform e-commerce modern untuk penjualan sepatu dengan fitur keranjang belanja, wishlist, filter produk, dan sistem checkout yang user-friendly.',
    tech: ['CodeIgniter 4', 'MySQL', 'JavaScript', 'Tailwind CSS'],
    features: ['Shopping Cart', 'Product Filter', 'Wishlist', 'Order Tracking'],
    gradient: 'from-orange-500 to-red-500'
  }
];
---

<section id="projects" class="py-20 bg-gray-950 relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute top-1/2 right-0 w-96 h-96 bg-cyan-500/10 rounded-full blur-3xl"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-16" data-aos="fade-up">
      <h2 class="text-4xl sm:text-5xl font-bold font-space-grotesk mb-4">
        Featured <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500">Projects</span>
      </h2>
      <div class="w-20 h-1 bg-gradient-to-r from-cyan-400 to-blue-500 mx-auto mb-4"></div>
      <p class="text-gray-400 max-w-2xl mx-auto">
        Beberapa project yang telah saya kerjakan untuk kebutuhan akademik dan klien
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {projects.map((project, index) => (
        <div 
          class="group bg-gray-900/50 backdrop-blur-sm rounded-2xl overflow-hidden border border-gray-800 hover:border-cyan-500/50 transition-all duration-300 hover:transform hover:scale-105"
          data-aos="fade-up"
          data-aos-delay={index * 100}
        >
          <!-- Project Header with Gradient -->
          <div class={`h-2 bg-gradient-to-r ${project.gradient}`}></div>
          
          <div class="p-8">
            <!-- Title -->
            <h3 class="text-2xl font-bold text-white mb-3 font-space-grotesk group-hover:text-cyan-400 transition-colors duration-300">
              {project.title}
            </h3>
            
            <!-- Description -->
            <p class="text-gray-400 mb-6 leading-relaxed">
              {project.description}
            </p>
            
            <!-- Features -->
            <div class="mb-6">
              <h4 class="text-sm font-semibold text-cyan-400 mb-3">Key Features:</h4>
              <div class="grid grid-cols-2 gap-2">
                {project.features.map((feature) => (
                  <div class="flex items-center gap-2 text-sm text-gray-300">
                    <svg class="w-4 h-4 text-cyan-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    <span>{feature}</span>
                  </div>
                ))}
              </div>
            </div>
            
            <!-- Tech Stack -->
            <div class="mb-6">
              <h4 class="text-sm font-semibold text-cyan-400 mb-3">Tech Stack:</h4>
              <div class="flex flex-wrap gap-2">
                {project.tech.map((tech) => (
                  <span class="px-3 py-1 bg-gray-800/50 text-gray-300 rounded-full text-xs font-medium border border-gray-700">
                    {tech}
                  </span>
                ))}
              </div>
            </div>
            
            <!-- Action Buttons -->
            <div class="flex gap-3">
              <button class="flex-1 px-4 py-2 bg-gradient-to-r from-cyan-500 to-blue-500 text-white rounded-lg font-medium hover:shadow-lg hover:shadow-cyan-500/50 transition-all duration-300 flex items-center justify-center gap-2">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
                View Code
              </button>
              <button class="px-4 py-2 border-2 border-cyan-400 text-cyan-400 rounded-lg font-medium hover:bg-cyan-400 hover:text-gray-900 transition-all duration-300 flex items-center justify-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                </svg>
                Demo
              </button>
            </div>
          </div>
        </div>
      ))}
    </div>
    
    <!-- View More -->
    <div class="text-center mt-12" data-aos="fade-up" data-aos-delay="400">
      <a 
        href="https://github.com/LilCode2704" 
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-4 bg-gray-900/50 border-2 border-cyan-400 text-cyan-400 font-semibold rounded-lg hover:bg-cyan-400 hover:text-gray-900 transition-all duration-300 hover:shadow-lg hover:shadow-cyan-400/50"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        View All Projects on GitHub
      </a>
    </div>
  </div>
</section>
