---
---

<section id="about" class="py-20 bg-gray-950 relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute top-0 left-0 w-96 h-96 bg-cyan-500/10 rounded-full blur-3xl"></div>
  <div class="absolute bottom-0 right-0 w-96 h-96 bg-blue-500/10 rounded-full blur-3xl"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-16" data-aos="fade-up">
      <h2 class="text-4xl sm:text-5xl font-bold font-space-grotesk mb-4">
        About <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500">Me</span>
      </h2>
      <div class="w-20 h-1 bg-gradient-to-r from-cyan-400 to-blue-500 mx-auto"></div>
    </div>
    
    <div class="max-w-4xl mx-auto">
      <div class="bg-gray-900/50 backdrop-blur-sm rounded-2xl p-8 sm:p-12 border border-gray-800 hover:border-cyan-500/50 transition-all duration-300" data-aos="fade-up" data-aos-delay="200">
        <div class="flex items-start gap-4 mb-6">
          <div class="w-12 h-12 bg-gradient-to-br from-cyan-400 to-blue-500 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
          </div>
          <div>
            <h3 class="text-2xl font-bold text-cyan-400 mb-2 font-space-grotesk">Mahasiswa Sistem Informasi</h3>
            <p class="text-gray-400 text-sm">Web Developer & Technology Enthusiast</p>
          </div>
        </div>
        
        <p class="text-gray-300 text-lg leading-relaxed mb-6">
          Mahasiswa Sistem Informasi yang fokus pada pengembangan web modern. Memiliki pengalaman dalam membangun aplikasi berbasis web untuk kebutuhan akademik maupun klien, serta tertarik pada pengembangan teknologi yang scalable dan efisien.
        </p>
        
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mt-8">
          <div class="text-center p-4 bg-gray-800/50 rounded-lg border border-gray-700 hover:border-cyan-500/50 transition-all duration-300" data-aos="fade-up" data-aos-delay="300">
            <div class="text-3xl font-bold text-cyan-400 mb-2 font-space-grotesk">10+</div>
            <div class="text-gray-400 text-sm">Projects Completed</div>
          </div>
          
          <div class="text-center p-4 bg-gray-800/50 rounded-lg border border-gray-700 hover:border-cyan-500/50 transition-all duration-300" data-aos="fade-up" data-aos-delay="400">
            <div class="text-3xl font-bold text-cyan-400 mb-2 font-space-grotesk">7+</div>
            <div class="text-gray-400 text-sm">Certifications</div>
          </div>
          
          <div class="text-center p-4 bg-gray-800/50 rounded-lg border border-gray-700 hover:border-cyan-500/50 transition-all duration-300" data-aos="fade-up" data-aos-delay="500">
            <div class="text-3xl font-bold text-cyan-400 mb-2 font-space-grotesk">2+</div>
            <div class="text-gray-400 text-sm">Years Experience</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
