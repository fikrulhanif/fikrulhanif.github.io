---
const navLinks = [
  { href: '#home', label: 'Home' },
  { href: '#about', label: 'About' },
  { href: '#skills', label: 'Skills' },
  { href: '#projects', label: 'Projects' },
  { href: '#certifications', label: 'Certifications' },
  { href: '#contact', label: 'Contact' },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 backdrop-blur-md border-b border-gray-800/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="#home" class="group flex items-center gap-3 relative">
        <!-- Logo Image -->
        <img 
          src="/android-chrome-512x512.png" 
          alt="FH Logo" 
          class="w-14 h-14 object-contain transition-transform duration-300 group-hover:scale-110"
        />
        
        <!-- Name (Hidden on mobile) -->
        <div class="hidden lg:flex flex-col">
          <span class="text-base font-bold text-white font-space-grotesk leading-tight">Fikrul Hanif</span>
          <span class="text-xs text-cyan-400 font-medium">Web Developer</span>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center space-x-1">
        {navLinks.map(link => (
          <a 
            href={link.href} 
            class="nav-link relative px-4 py-2 text-gray-300 hover:text-cyan-400 transition-all duration-300 text-sm font-medium group"
          >
            <span class="relative z-10">{link.label}</span>
            <!-- Hover Background -->
            <div class="absolute inset-0 bg-cyan-400/10 rounded-lg scale-0 group-hover:scale-100 transition-transform duration-300"></div>
            <!-- Active Indicator -->
            <div class="absolute bottom-0 left-1/2 transform -translate-x-1/2 w-0 h-0.5 bg-gradient-to-r from-cyan-400 to-blue-500 group-hover:w-full transition-all duration-300"></div>
          </a>
        ))}
        
        <!-- CTA Button -->
        <a 
          href="#contact" 
          class="ml-4 px-6 py-2.5 bg-gradient-to-r from-cyan-500 to-blue-500 text-white font-semibold rounded-lg text-sm hover:shadow-lg hover:shadow-cyan-500/50 transition-all duration-300 hover:scale-105"
        >
          Let's Talk
        </a>
      </div>

      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="md:hidden relative w-10 h-10 text-gray-300 hover:text-cyan-400 focus:outline-none flex items-center justify-center">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-gray-900/98 backdrop-blur-md border-t border-gray-800/50">
    <div class="px-4 pt-4 pb-6 space-y-2">
      {navLinks.map(link => (
        <a 
          href={link.href} 
          class="nav-link block px-4 py-3 text-gray-300 hover:text-cyan-400 hover:bg-gray-800/50 rounded-lg transition-all duration-200 font-medium"
        >
          {link.label}
        </a>
      ))}
      <a 
        href="#contact" 
        class="block px-4 py-3 bg-gradient-to-r from-cyan-500 to-blue-500 text-white font-semibold rounded-lg text-center mt-4 hover:shadow-lg hover:shadow-cyan-500/50 transition-all duration-300"
      >
        Let's Talk
      </a>
    </div>
  </div>
</nav>
